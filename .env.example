NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Brevo (server-side only) ─────────────────────────────────────────────
# Same API key used for marketing + transactional emails.
BREVO_API_KEY=your-brevo-api-key

# Verified sender for the contact-form notification email (must be a sender
# validated in Brevo → Settings → Senders, or an authenticated domain).
BREVO_SENDER_EMAIL=hello@popimpactlab.com

# Brevo list IDs (numeric). Newsletter opt-ins go to the newsletter list;
# event registrants go to the event list.
BREVO_NEWSLETTER_LIST_ID=3
BREVO_EVENT_LIST_ID=4
# Legacy fallback for the newsletter list if BREVO_NEWSLETTER_LIST_ID is unset.
BREVO_LIST_ID=3

# Shared secret protecting POST /api/event-signup (Infomaniak webhook / Make /
# Zapier). Send it as `Authorization: Bearer <secret>` or `?secret=<secret>`.
BREVO_WEBHOOK_SECRET=generate-a-long-random-string

# Custom Brevo contact attributes to create (Contacts → Settings → Contact
# attributes), all type Text: FIRST_NAME, SURNAME, SOURCE, AGE_RANGE,
# JOB_FIELD, REGION.
